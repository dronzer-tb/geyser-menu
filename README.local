## Python Client Example

```python
import socket
import struct
import json

class GeyserMenuClient:
    def __init__(self, host: str, port: int):
        self.host = host
        self.port = port
        self.sock = None
    
    def connect(self):
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.sock.connect((self.host, self.port))
    
    def send_packet(self, packet_type: str, payload: dict):
        packet = {
            "type": packet_type,
            "payload": json.dumps(payload)
        }
        data = json.dumps(packet).encode('utf-8')
        # Send length prefix (4 bytes, big endian)
        self.sock.sendall(struct.pack('>I', len(data)) + data)
    
    def receive_packet(self) -> dict:
        # Read length prefix
        length_data = self.sock.recv(4)
        length = struct.unpack('>I', length_data)[0]
        # Read packet data
        data = self.sock.recv(length)
        return json.loads(data.decode('utf-8'))
    
    def authenticate(self, server_id: str, secret_key: str):
        self.send_packet("AUTH_REQUEST", {
            "serverIdentifier": server_id,
            "secretKey": secret_key
        })
        response = self.receive_packet()
        print(f"Auth response: {response}")
        return response
    
    def send_simple_form(self, player_uuid: str, title: str, content: str, buttons: list):
        import uuid
        self.send_packet("FORM_REQUEST", {
            "request_id": str(uuid.uuid4()),
            "player_uuid": player_uuid,
            "form_type": "simple",
            "title": title,
            "content": content,
            "buttons": [{"text": btn} for btn in buttons]
        })
    
    def close(self):
        if self.sock:
            self.sock.close()

# Usage example
if __name__ == "__main__":
    client = GeyserMenuClient("localhost", 19133)
    client.connect()
    client.authenticate("my-server", "your-secret-key")
    
    # Send a form to a player
    client.send_simple_form(
        "00000000-0000-0000-0009-01f200e0da15",
        "Welcome!",
        "Choose an option:",
        ["Option 1", "Option 2", "Option 3"]
    )
    
    # Wait for response
    response = client.receive_packet()
    print(f"Form response: {response}")
    
    client.close()
```

