## Raw TCP Client Example (Java)

If you want to implement your own TCP client:

```java
import java.io.*;
import java.net.Socket;
import java.nio.ByteBuffer;
import java.nio.charset.StandardCharsets;

public class GeyserMenuClient {
    private Socket socket;
    private DataInputStream in;
    private DataOutputStream out;
    
    public void connect(String host, int port) throws IOException {
        socket = new Socket(host, port);
        in = new DataInputStream(socket.getInputStream());
        out = new DataOutputStream(socket.getOutputStream());
    }
    
    public void authenticate(String serverIdentifier, String secretKey) throws IOException {
        String payload = String.format(
            "{\"serverIdentifier\":\"%s\",\"secretKey\":\"%s\"}",
            serverIdentifier, secretKey
        );
        sendPacket("AUTH_REQUEST", payload);
        
        String response = receivePacket();
        System.out.println("Auth response: " + response);
    }
    
    public void sendForm(String playerUuid, String title, String content, String... buttons) throws IOException {
        StringBuilder buttonsJson = new StringBuilder("[");
        for (int i = 0; i < buttons.length; i++) {
            if (i > 0) buttonsJson.append(",");
            buttonsJson.append("{\"text\":\"").append(buttons[i]).append("\"}");
        }
        buttonsJson.append("]");
        
        String payload = String.format(
            "{\"request_id\":\"%s\",\"player_uuid\":\"%s\",\"form_type\":\"simple\",\"title\":\"%s\",\"content\":\"%s\",\"buttons\":%s}",
            java.util.UUID.randomUUID().toString(),
            playerUuid,
            title,
            content,
            buttonsJson.toString()
        );
        
        sendPacket("FORM_REQUEST", payload);
    }
    
    private void sendPacket(String type, String payload) throws IOException {
        String json = String.format("{\"type\":\"%s\",\"payload\":%s}", 
            type, 
            com.google.gson.JsonParser.parseString(payload).toString());
        
        byte[] data = json.getBytes(StandardCharsets.UTF_8);
        out.writeInt(data.length);
        out.write(data);
        out.flush();
    }
    
    private String receivePacket() throws IOException {
        int length = in.readInt();
        byte[] data = new byte[length];
        in.readFully(data);
        return new String(data, StandardCharsets.UTF_8);
    }
    
    public void close() throws IOException {
        if (socket != null) socket.close();
    }
}
```

